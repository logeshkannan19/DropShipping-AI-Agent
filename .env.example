# =============================================================================
# Environment Variables Template
# Copy this file to .env and configure your values
# =============================================================================

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=DropShipping AI Agent
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false

# =============================================================================
# Server Settings
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1
SERVER_RELOAD=true
LOG_LEVEL=INFO

# =============================================================================
# Database Settings
# =============================================================================
DATABASE_URL=sqlite+aiosqlite:///./data/dropshipping.db
DATABASE_ECHO=false

# =============================================================================
# Security Settings
# =============================================================================
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
SECURITY_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# OpenAI Settings
# =============================================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_USE_MOCK=true

# =============================================================================
# Redis Settings
# =============================================================================
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL=3600

# =============================================================================
# Pricing Settings
# =============================================================================
PRICING_DEFAULT_MARGIN=0.30
PRICING_MIN_MARGIN=0.15
PRICING_MAX_MARGIN=0.60

# =============================================================================
# Agent Settings
# =============================================================================
AGENT_MAX_PRODUCTS=50
AGENT_TOP_PRODUCTS=10
AGENT_CONFIDENCE_THRESHOLD=0.6

# =============================================================================
# CORS Settings
# =============================================================================
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8501"]
